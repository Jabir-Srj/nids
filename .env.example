# NIDS Environment Configuration
# Copy this file to .env and configure for your environment

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Database Configuration
DATABASE_URL=postgresql://nids:nids_secure_pass@localhost:5432/nids
# For development with SQLite (optional):
# DATABASE_URL=sqlite:///nids.db

# Database Pool
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Threat Intelligence APIs
ABUSEIPDB_API_KEY=your-abuseipdb-key
NVD_API_KEY=your-nvd-key
MAXMIND_LICENSE_KEY=your-maxmind-key

# Packet Capture Configuration
CAPTURE_INTERFACE=eth0
PACKET_SNAPLEN=65535
BPF_FILTER=
PCAP_DIRECTORY=/tmp/nids/pcap

# ML Model Configuration
ML_MODEL_PATH=/tmp/nids/models/anomaly_detector.pkl
ML_RETRAIN_INTERVAL=3600
ML_MIN_SAMPLES_TRAIN=1000
ML_ANOMALY_THRESHOLD=0.7

# Alert Configuration
ALERT_STORAGE_PATH=/tmp/nids/alerts
ALERT_RETENTION_DAYS=90
ALERT_BATCH_SIZE=100

# Logging
LOG_FILE=/var/log/nids/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Nginx Configuration
NGINX_PORT=80
NGINX_SSL_PORT=443
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Docker Configuration
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=nids
DOCKER_IMAGE_TAG=latest

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Feature flags
ENABLE_SIGNATURE_DETECTION=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_THREAT_INTEL=false
ENABLE_PCAP_UPLOAD=true
